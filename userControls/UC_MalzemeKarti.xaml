<UserControl x:Class="MaliyeHesaplama.userControls.UC_MalzemeKarti"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MaliyeHesaplama.userControls"
             xmlns:common="clr-namespace:MaliyeHesaplama.userControls.Common"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" FontFamily="Bahnschrift Light">
    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0">
            <common:ButtonBar x:Name="ButtonBar" DockPanel.Dock="Top" />
        </Border>
        <TabControl Grid.Row="1">
            <TabItem Header="Genel">
                <DockPanel HorizontalAlignment="Left" Margin="0,0,5,0">
                    <Border>
                        <StackPanel>
                            <DockPanel Margin="0,1">
                                <Label Content="Kodu :"  Width="95"/>
                                <TextBox x:Name="txtKodu" Width="200" VerticalContentAlignment="Center"/>
                                <CheckBox Content="Kullanımda" IsChecked="True" x:Name="chkKullanimda" VerticalContentAlignment="Center"/>
                            </DockPanel>
                            <DockPanel Margin="0,0,0,1">
                                <Label Content="Adı :" Width="95"/>
                                <TextBox x:Name="txtAdi" VerticalContentAlignment="Center"/>
                            </DockPanel>
                            <Grid x:Name="gridModel" Tag="modelkarti">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <GroupBox Grid.Column="0" Padding="0,4,0,0">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,2">
                                            <Label Content="Marka : " Width="80"/>
                                            <TextBox Width="100"/>
                                            <Button Width="24" Content="🔎" Background="Transparent" BorderBrush="LightGray"/>
                                        </DockPanel>
                                        <DockPanel Margin="0,0,0,2">
                                            <Label Content="Departman : " Width="80"/>
                                            <TextBox Width="100"/>
                                            <Button Width="24" Content="🔎" Background="Transparent" BorderBrush="LightGray"/>
                                        </DockPanel>
                                        <DockPanel>
                                            <Label Content="Grup Kodu : " Width="80"/>
                                            <TextBox Width="100"/>
                                            <Button Width="24" Content="🔎" Background="Transparent" BorderBrush="LightGray"/>
                                        </DockPanel>
                                    </StackPanel>
                                </GroupBox>
                                <GroupBox Grid.Column="1" Padding="0,4,0,0">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,2">
                                            <Label Content="Sezon : " Width="80"/>
                                            <TextBox Width="100"/>
                                            <Button Width="24" Content="🔎" Background="Transparent" BorderBrush="LightGray"/>
                                        </DockPanel>
                                        <DockPanel Margin="0,0,0,2">
                                            <Label Content="Cinsiyet : " Width="80"/>
                                            <TextBox Width="100"/>
                                            <Button Width="24" Content="🔎" Background="Transparent" BorderBrush="LightGray"/>
                                        </DockPanel>
                                        <DockPanel>
                                            <Label Content="Kategori : " Width="80"/>
                                            <TextBox Width="100"/>
                                            <Button Width="24" Content="🔎" Background="Transparent" BorderBrush="LightGray"/>
                                        </DockPanel>
                                    </StackPanel>
                                </GroupBox>
                            </Grid>
                        </StackPanel>
                    </Border>
                </DockPanel>
            </TabItem>
        </TabControl>
        
    </Grid>
</UserControl>
