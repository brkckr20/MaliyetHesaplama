<UserControl x:Class="MaliyeHesaplama.userControls.UC_MalzemeKarti"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MaliyeHesaplama.userControls"
             xmlns:common="clr-namespace:MaliyeHesaplama.userControls.Common"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" FontFamily="Bahnschrift Light">
    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0">
            <common:ButtonBar x:Name="ButtonBar" DockPanel.Dock="Top" />
        </Border>
        <StackPanel Grid.Row="1">
            <StackPanel>
                <DockPanel Margin="0,1">
                    <Label Content="Kodu :"  Width="86"/>
                    <TextBox x:Name="txtKodu" Width="200" VerticalContentAlignment="Center"/>
                    <CheckBox Content="Kullanımda" IsChecked="True" x:Name="chkKullanimda" VerticalContentAlignment="Center" Margin="8,0,0,0"/>
                </DockPanel>
                <DockPanel Margin="0,0,0,1">
                    <Label Content="Adı :" Width="86"/>
                    <TextBox x:Name="txtAdi" Width="300"  VerticalContentAlignment="Center" HorizontalAlignment="Left"/>
                </DockPanel>
            </StackPanel>
            <TabControl x:Name="tabControl1">
                <TabItem Header="Genel" Height="24">
                    <DockPanel HorizontalAlignment="Left" Margin="0,0,5,0">
                        <Border>
                            <StackPanel>
                                <Grid Tag="modelkarti">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <GroupBox Grid.Column="0" Padding="0,4,0,0">
                                        <StackPanel>
                                            <DockPanel Margin="0,0,0,2">
                                                <Label x:Name="asdasf" Content="Marka : " Width="80"/>
                                                <TextBox x:Name="txtModelMarka" Width="100" VerticalContentAlignment="Center"/>
                                                <Button x:Name="modelMarka" Click="modelMarka_Click" Width="24" Content="🔎" Background="Transparent" BorderBrush="LightGray"/>
                                            </DockPanel>
                                            <DockPanel Margin="0,0,0,2">
                                                <Label Content="Sezon : " Width="80"/>
                                                <TextBox x:Name="txtModelSezon" Width="100" VerticalContentAlignment="Center"/>
                                                <Button x:Name="btnModelSezon" Click="btnModelSezon_Click" Width="24" Content="🔎" Background="Transparent" BorderBrush="LightGray"/>
                                            </DockPanel>
                                        </StackPanel>
                                    </GroupBox>
                                    <GroupBox Grid.Column="1" Padding="0,4,0,0">
                                        <StackPanel>
                                            <DockPanel Margin="0,0,0,2">
                                                <Label Content="Cinsiyet : " Width="80"/>
                                                <TextBox x:Name="txtModelCinsiyet" Width="100" VerticalContentAlignment="Center"/>
                                                <Button x:Name="btnModelCinsiyet" Click="btnModelCinsiyet_Click" Width="24" Content="🔎" Background="Transparent" BorderBrush="LightGray"/>
                                            </DockPanel>
                                            <DockPanel>
                                                <Label Content="Kategori : " Width="80"/>
                                                <TextBox x:Name="txtModelKategori" Width="100" VerticalContentAlignment="Center"/>
                                                <Button x:Name="btnModelKategori" Click="btnModelKategori_Click" Width="24" Content="🔎" Background="Transparent" BorderBrush="LightGray"/>
                                            </DockPanel>
                                        </StackPanel>
                                    </GroupBox>
                                </Grid>
                                <Grid x:Name="gridModel1">
                                    <GroupBox Grid.Column="0" Padding="0,4,0,0" Header=" Müşteri Bilgileri ">
                                        <StackPanel>
                                            <DockPanel Margin="0,0,0,2" HorizontalAlignment="Left">
                                                <Label Content="Müşteri No: " Width="80"/>
                                                <TextBox x:Name="txtFirma" Width="100" VerticalContentAlignment="Center"/>
                                                <Button x:Name="btnFirmaSecimi" Click="btnFirmaSecimi_Click" Width="24" Content="🔎" Background="Transparent" BorderBrush="LightGray"/>
                                                <TextBlock x:Name="tbFirma" VerticalAlignment="Center" Margin="4,0,0,0" Text=""/>
                                            </DockPanel>
                                            <DockPanel Margin="0,0,0,2" HorizontalAlignment="Left">
                                                <Label Content="M. Model No: " Width="80"/>
                                                <TextBox Width="100" VerticalContentAlignment="Center"/>
                                            </DockPanel>
                                        </StackPanel>
                                    </GroupBox>
                                </Grid>
                                <Grid x:Name="gridModel2">
                                    <GroupBox Grid.Column="0" Padding="0,4,0,0" Header="">
                                        <StackPanel>
                                            <DockPanel Margin="0,0,0,2" HorizontalAlignment="Left">
                                                <Label Content="GTIP No : " Width="80"/>
                                                <TextBox x:Name="txtGTIP" Width="100" VerticalContentAlignment="Center"/>
                                                <Button x:Name="btnGTIP" Click="btnGTIP_Click" Width="24" Content="🔎" Background="Transparent" BorderBrush="LightGray"/>
                                                <TextBlock x:Name="tbGTIP" VerticalAlignment="Center" Margin="4,0,0,0" Text=""/>
                                            </DockPanel>
                                            <DockPanel Margin="0,0,0,2" HorizontalAlignment="Left">
                                                <Label Content="Özel Kod : " Width="80"/>
                                                <TextBox Width="100" VerticalContentAlignment="Center"/>
                                            </DockPanel>
                                        </StackPanel>
                                    </GroupBox>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </DockPanel>
                </TabItem>
                <TabItem Header="Renk / Beden">
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition  Width="Auto"/>
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <GroupBox Header="Bileşenler" Grid.Column="0" Margin="0,0,5,0">
                            <StackPanel>
                                <DockPanel Grid.Row="0" Width="250" HorizontalAlignment="Left">
                                    <TextBox x:Name="txtRenk" Background="AliceBlue" Width="150" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" FontSize="20"/>
                                    <StackPanel>
                                        <Button Click="btnVaryantEkle_Click" x:Name="btnVaryantEkle" Content="Ekle" Margin="4,0,0,0" Background="Transparent"/>
                                        <Button Click="btnVaryantSil_Click" x:Name="btnVaryantSil" Content="Sil" Margin="4,2,0,0" Background="Transparent"/>
                                        <Button Click="btnVaryantTumunuTemizle_Click" x:Name="btnVaryantTumunuTemizle" Content="Tümünü Sil" Margin="4,2,0,0" Background="Transparent"/>
                                    </StackPanel>
                                </DockPanel>
                                <ListBox x:Name="lstRenkler" Grid.Row="1" Width="250" HorizontalAlignment="Left" Margin="0,4,0,0" FontFamily="Bahnschrift Light"/>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="Bedenler" Grid.Column="1">
                            <StackPanel  Margin="0,0,5,0">
                                <DockPanel Grid.Row="0" Width="250" HorizontalAlignment="Left">
                                    <TextBox x:Name="txtBeden" Background="AliceBlue" Width="150" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" FontSize="20"/>
                                    <StackPanel>
                                        <Button Click="btnBedenEkle_Click" x:Name="btnBedenEkle" Content="Beden Ekle" Margin="4,0,0,0" Background="Transparent"/>
                                        <Button Click="btnBedenSil_Click" x:Name="btnBedenSil" Content="Beden Sil" Margin="4,2,0,0" Background="Transparent"/>
                                        <Button Click="btnTumunuTemizle_Click" x:Name="btnTumunuTemizle" Content="Tümünü Sil" Margin="4,2,0,0" Background="Transparent"/>
                                    </StackPanel>
                                </DockPanel>
                                <ListBox x:Name="lstBedenler" Grid.Row="1" Width="250" HorizontalAlignment="Left" Margin="0,4,0,0" FontFamily="Bahnschrift Light"/>
                            </StackPanel>
                        </GroupBox>
                    </Grid>
                </TabItem>
                <TabItem Header="Fiyat">
                    <!--burdan devam et - 03.04.2026-->
                </TabItem>
                <TabItem Header="Reçete Detayı">
                    <TabControl>
                        <TabItem Header="Kumaş">
                            <Label Content="Kumaş bilgileri gelecek"/>
                        </TabItem>
                        <TabItem Header="İplik">
                            <Label Content="İplik bilgileri gelecek"/>
                        </TabItem>
                        <TabItem Header="Aksesuar">
                            <Label Content="Aksesuar bilgileri gelecek"/>
                        </TabItem>
                    </TabControl>
                </TabItem>
                <TabItem Header="Renk/Beden Barkod">
                    <Label Content="renk beden bilgisine barkod bilgilerinin girileceği alan"></Label>
                </TabItem>
                <TabItem Header="Renk/Beden Açıklama">
                    <Label Content="renk beden bilgisine açıklama bilgilerinin girileceği alan"></Label>
                </TabItem>
                <TabItem Header="Renk/Beden Sticker">
                    <Label Content="renk beden bilgisine açıklama bilgilerinin girileceği alan"></Label>
                </TabItem>
                <TabItem Header="Açıklamalar">
                    <Label Content="Siparişe bağlı açıklamaların girileceği alan"></Label>
                </TabItem>
                <TabItem Header="Ekler">
                    <Label Content="Siparişe bağlı eklerin girileceği tablo"></Label>
                </TabItem>
            </TabControl>
        </StackPanel>


    </Grid>
</UserControl>
