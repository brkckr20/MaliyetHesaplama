<UserControl x:Class="MaliyeHesaplama.userControls.OrderGirisi"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MaliyeHesaplama.userControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <Button Content="Varyant Ekle"
            Width="120"
            Margin="0,0,10,10"
            Click="AddVariant_Click"/>

            <Button Content="Beden Ekle"
                Width="120"
                Margin="0,0,10,10"
                Click="AddSize_Click"/>

        </StackPanel>

        <DataGrid x:Name="MatrixGrid"
              Grid.Row="1"
              AutoGenerateColumns="False"
              CanUserAddRows="True"/>

    </Grid>
</UserControl>
