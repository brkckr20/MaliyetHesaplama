<Window x:Class="MaliyeHesaplama.v2.Windows.winStokSecimiV2"
          xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
          xmlns:control="clr-namespace:FilterDataGrid;assembly=FilterDataGrid"
          Title="Stok Seçimi" Height="500" Width="900" WindowStartupLocation="CenterScreen" Icon="/News.png">
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <control:FilterDataGrid Grid.Row="0" x:Name="grid" 
                  CanUserAddRows="False" IsReadOnly="True" SelectionMode="Extended"
                  GridLinesVisibility="All" HorizontalGridLinesBrush="LightGray" VerticalGridLinesBrush="LightGray"
                  FilterLanguage="Turkish" ShowStatusBar="True" ShowRowsCount="True"
                  AutoGenerateColumns="True" AutoGeneratingColumn="grid_AutoGeneratingColumn" Loaded="Window_Loaded">
            <control:FilterDataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Kolon Seçicisi" Click="ctxKolonSecici_Click"/>
                    <Separator/>
                    <MenuItem Header="Excel Olarak Aktar" Click="ctxExcelAktar_Click"/>
                    <Separator/>
                    <MenuItem Header="Seçili Satırı Aktar" Click="btnAktar_Click"/>
                </ContextMenu>
            </control:FilterDataGrid.ContextMenu>
        </control:FilterDataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="btnAktar" Content="Aktar" Width="80" Height="30" Margin="5,0,5,0" Click="btnAktar_Click"/>
            <Button x:Name="btnVazgec" Content="Vazgeç" Width="80" Height="30" Margin="5,0,0,0" Click="btnVazgec_Click"/>
        </StackPanel>
    </Grid>
</Window>