<Window x:Class="MaliyeHesaplama.v2.Windows.winFisListesiV2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:control="clr-namespace:FilterDataGrid;assembly=FilterDataGrid"
        Title="Fiş Listesi" Height="450" Width="800" WindowStartupLocation="CenterScreen" Loaded="Window_Loaded" Icon="/News.png">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" PanningMode="Both" PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
            <control:FilterDataGrid x:Name="grid" FontSize="12" VerticalContentAlignment="Center" IsReadOnly="True"
                GridLinesVisibility="All" HorizontalGridLinesBrush="#ececec" VerticalGridLinesBrush="#ececec"
                FilterLanguage="Turkish" ShowStatusBar="True" AutoGenerateColumns="True"
                AutoGeneratingColumn="grid_AutoGeneratingColumn" MouseDoubleClick="grid_MouseDoubleClick"
                ColumnReordered="grid_ColumnReordered">
                <control:FilterDataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Excel Aktar" Click="ExportToExcel_Click"/>
                        <Separator/>
                        <MenuItem Header="Kolon Seçicisi" Click="MenuItem_Click"/>
                    </ContextMenu>
                </control:FilterDataGrid.ContextMenu>
            </control:FilterDataGrid>
        </ScrollViewer>
    </Grid>
</Window>
