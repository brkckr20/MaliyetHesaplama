<Window x:Class="MaliyeHesaplama.v2.Windows.winFasonGidenlerListesiV2"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:control="clr-namespace:FilterDataGrid;assembly=FilterDataGrid"
         Title="Fason Gidenler Listesi" Height="500" Width="900" WindowStartupLocation="CenterScreen" Icon="/News.png"
         Loaded="Window_Loaded">
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <control:FilterDataGrid Grid.Row="0" x:Name="grid" 
                  FontSize="12" VerticalContentAlignment="Center" IsReadOnly="True" GridLinesVisibility="All"
                  HorizontalGridLinesBrush="#ececec" VerticalGridLinesBrush="#ececec"
                  FilterLanguage="Turkish" ShowStatusBar="True" ShowRowsCount="True" ShowElapsedTime="True"
                  AutoGenerateColumns="True" AutoGeneratingColumn="grid_AutoGeneratingColumn" SelectionMode="Extended">
            <control:FilterDataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Kolon Seçicisi" Click="MenuItem_Click"/>
                </ContextMenu>
            </control:FilterDataGrid.ContextMenu>
        </control:FilterDataGrid>
        
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="btnAktar" Content="Aktar" Width="80" Height="30" Margin="5,0,5,0" Click="btnAktar_Click"/>
            <Button x:Name="btnVazgec" Content="Vazgeç" Width="80" Height="30" Margin="5,0,0,0" Click="btnVazgec_Click"/>
        </StackPanel>
    </Grid>
</Window>