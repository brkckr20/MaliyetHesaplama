<UserControl x:Class="MaliyeHesaplama.v2.UserControls.UC_DepoKartiV2"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:common="clr-namespace:MaliyeHesaplama.userControls.Common"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800" FontFamily="Bahnschrift Light">
    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0">
            <common:ButtonBar x:Name="ButtonBar" DockPanel.Dock="Top" />
        </Border>
        <TabControl Grid.Row="1" Background="White">
            <TabItem Header="Genel">
                <StackPanel>
                    <DockPanel Margin="0,1">
                        <Label Content="Kodu :" Width="86"/>
                        <TextBox x:Name="txtKodu" Width="200" VerticalContentAlignment="Center"/>
                        <CheckBox Content="Kullanımda" IsChecked="True" x:Name="chkKullanimda" VerticalContentAlignment="Center" Margin="8,0,0,0"/>
                    </DockPanel>
                    <DockPanel Margin="0,0,0,1">
                        <Label Content="Adı :" Width="86"/>
                        <TextBox x:Name="txtAdi" Width="300" VerticalContentAlignment="Center" HorizontalAlignment="Left"/>
                    </DockPanel>
                </StackPanel>
            </TabItem>
            <TabItem Header="Adres">
                <StackPanel>
                    <DockPanel Margin="0,1">
                        <Label Content="Adres 1 :" Width="86"/>
                        <TextBox x:Name="txtAdres1" Width="300" VerticalContentAlignment="Center" HorizontalAlignment="Left"/>
                    </DockPanel>
                    <DockPanel Margin="0,0,0,1">
                        <Label Content="Adres 2 :" Width="86"/>
                        <TextBox x:Name="txtAdres2" Width="300" VerticalContentAlignment="Center" HorizontalAlignment="Left"/>
                    </DockPanel>
                    <DockPanel Margin="0,0,0,1">
                        <Label Content="İlçe :" Width="86"/>
                        <TextBox x:Name="txtIlce" Width="200" VerticalContentAlignment="Center" HorizontalAlignment="Left"/>
                    </DockPanel>
                    <DockPanel Margin="0,0,0,1">
                        <Label Content="İl :" Width="86"/>
                        <TextBox x:Name="txtIl" Width="200" VerticalContentAlignment="Center" HorizontalAlignment="Left"/>
                    </DockPanel>
                    <DockPanel Margin="0,0,0,1">
                        <Label Content="Posta Kodu :" Width="86"/>
                        <TextBox x:Name="txtPostaKodu" Width="100" VerticalContentAlignment="Center" HorizontalAlignment="Left"/>
                    </DockPanel>
                    <DockPanel Margin="0,0,0,1">
                        <Label Content="Telefon :" Width="86"/>
                        <TextBox x:Name="txtTelefon" Width="200" VerticalContentAlignment="Center" HorizontalAlignment="Left"/>
                    </DockPanel>
                    <DockPanel Margin="0,0,0,1">
                        <Label Content="E-posta :" Width="86"/>
                        <TextBox x:Name="txtEmail" Width="200" VerticalContentAlignment="Center" HorizontalAlignment="Left"/>
                    </DockPanel>
                </StackPanel>
            </TabItem>
        </TabControl>
        
    </Grid>
</UserControl>